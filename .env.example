# Base URL of your existing Traccar server (REST + WebSocket).
# Server-only -- never exposed to the browser, never prefixed NEXT_PUBLIC_.
TRACCAR_API_URL="https://traccar.example.com"

# 32-byte secret used to sign/encrypt our own session cookie (jose).
# Generate with: openssl rand -base64 32
SESSION_SECRET=""

# Supabase Postgres, pooled connection (Supavisor/pgbouncer, port 6543) -- used
# by the app at runtime via the Prisma driver adapter (lib/prisma.ts).
DATABASE_URL="postgresql://postgres:password@db.example.supabase.co:6543/postgres?pgbouncer=true"

# Supabase Postgres, direct connection (port 5432) -- used only by Prisma
# Migrate/introspect (prisma.config.ts), never at app runtime.
DIRECT_URL="postgresql://postgres:password@db.example.supabase.co:5432/postgres"

# MapTiler API key for the live map's tile layer (app/(dashboard)/map/live-map.tsx).
# CARTO's free tiles don't render building/POI name labels at all; MapTiler's do.
# Free tier, no card required: https://cloud.maptiler.com/account/keys/
# NEXT_PUBLIC_ because it's read in a client component and baked in at build time.
NEXT_PUBLIC_MAPTILER_API_KEY=""

# Max age (days) a running trip's un-computed window may reach before the trip
# is auto-invalidated (lib/dal/trips.ts). MUST be <= your Traccar server's
# positions-retention/cleanup window: trip distance is computed from Traccar's
# stored positions, so anything older is gone for good. Defaults to 7.
TRIP_MAX_AGE_DAYS=7
