# Base URL of your existing Traccar server (REST + WebSocket).
# Server-only -- never exposed to the browser, never prefixed NEXT_PUBLIC_.
TRACCAR_API_URL="https://traccar.example.com"

# 32-byte secret used to sign/encrypt our own session cookie (jose).
# Generate with: openssl rand -base64 32
SESSION_SECRET=""

# Supabase Postgres, pooled connection (Supavisor/pgbouncer, port 6543) -- used
# by the app at runtime via the Prisma driver adapter (lib/prisma.ts).
DATABASE_URL="postgresql://postgres:password@db.example.supabase.co:6543/postgres?pgbouncer=true"

# Supabase Postgres, direct connection (port 5432) -- used only by Prisma
# Migrate/introspect (prisma.config.ts), never at app runtime.
DIRECT_URL="postgresql://postgres:password@db.example.supabase.co:5432/postgres"
