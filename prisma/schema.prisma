// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Traccar owns users/devices/geofences via its own REST API and database,
// which this app never touches directly. Trip is first-party data with no
// Traccar equivalent. Reference Traccar entities loosely by numeric id only
// (traccarDeviceId, startedByUserId) -- never duplicate them as FKs here.
enum TripStatus {
  ACTIVE
  COMPLETED
  DISCARDED
}

model Trip {
  id              String     @id @default(cuid())
  traccarDeviceId Int
  startedByUserId Int
  name            String
  status          TripStatus @default(ACTIVE)
  startedAt       DateTime
  endedAt         DateTime?
  // Persisted running total, advanced incrementally: each distance
  // computation resumes from lastComputedFixTime instead of re-reading the
  // whole trip, so a long trip stays computable as long as it's refreshed
  // at least once within Traccar's positions-retention window.
  distanceMeters      Float     @default(0)
  // fixTime of the last *processed* raw position (resume point for the next
  // incremental compute -- includes positions the noise filter rejected).
  lastComputedFixTime DateTime?
  // Noise-filter anchor: the last *accepted* point. Kept separately from the
  // resume point so parked-GPS-drift gating stays exact across checkpoints.
  lastAcceptedLat     Float?
  lastAcceptedLon     Float?
  // Set when status becomes DISCARDED (e.g. position history expired before
  // the distance was computed -- a trip someone forgot to stop).
  invalidReason       String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([traccarDeviceId, status])
  @@index([startedAt])
}
